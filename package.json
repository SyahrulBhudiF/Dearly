{
  "name": "dearly",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "infra"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "test": "turbo run test",
    "lint": "oxlint .",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "prepare": "husky",
    "dev": "turbo run dev",
    "deploy": "cd infra && bun run deploy",
    "destroy": "cd infra && bun run destroy"
  },
  "dependencies": {
    "@effect/platform-browser": ">=4.0.0-beta.97",
    "effect": ">=4.0.0-beta.97",
    "foldkit": "^0.127.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "@effect/vitest": ">=4.0.0-beta.97",
    "@foldkit/oxlint-plugin": "^0.3.0",
    "alchemy": "^2.0.0-beta.61",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "turbo": "^2.10.4",
    "typescript": "^7.0.2",
    "vite": "latest",
    "vitest": "latest"
  },
  "lint-staged": {
    "*.ts": [
      "oxlint --fix",
      "oxfmt --write"
    ]
  },
  "packageManager": "bun@1.3.14"
}
